# Cloud Run env vars for docs.examples.notes.sqlspec.cloud_run_jwt.
#
# Copy this file to `.cloud_run.env` (gitignored locally) and deploy with:
#
#     gcloud run deploy notes-cloud-run-jwt \
#       --env-vars-file=docs/examples/notes/sqlspec/.cloud_run.env
#
# For real deployments, prefer Cloud Run's Secret Manager integration for
# JWT_SIGNING_KEY rather than plain env vars:
#   https://cloud.google.com/run/docs/configuring/services/secrets
#
# ---------------------------------------------------------------------------

# Database DSN. The example supports SQLite out of the box; swap for a
# Cloud SQL / AlloyDB DSN when deploying.
DATABASE_URL=sqlite:///.reference-notes-sqlspec-cloud-run.sqlite

# HS256 signing secret shared by /auth/login and the MCP token validator.
# REQUIRED — the app refuses to boot without it. Use Secret Manager in prod.
JWT_SIGNING_KEY=change-me

# JWT issuer and audience. Defaults match the foundation's locked values;
# override these when you front the app with a real identity provider.
JWT_ISSUER=http://localhost:8000/auth
JWT_AUDIENCE=http://localhost:8000/api

# Cloud Run injects PORT at container start; this default only applies to
# local docker runs.
PORT=8080

# uvicorn log level passed through when running as __main__.
LOG_LEVEL=info
